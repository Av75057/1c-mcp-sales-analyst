DEEPSEEK_API_KEY=sk-your-key-here
C1_BASE_URL=http://localhost/1c/api
C1_USERNAME=service_user
C1_PASSWORD=service_password
MCP_HOST=0.0.0.0
MCP_PORT=8000
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=2000
LOG_LEVEL=DEBUG
USE_MOCK_DATA=true

# Таймауты и retry
C1_TIMEOUT_SECONDS=60
C1_CONNECT_TIMEOUT_SECONDS=10
C1_MAX_RETRIES=3
C1_RETRY_DELAY_SECONDS=5

# Batch-запросы
C1_BATCH_MAX_REQUESTS=10
C1_BATCH_TIMEOUT_SECONDS=120

# Кэширование
CACHE_TTL_SECONDS=300
CACHE_MAX_SIZE=1000

# === БЕЗОПАСНОСТЬ ===
# Секретный ключ для JWT (минимум 32 байта, сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))")
JWT_SECRET_KEY=change-me-in-production-use-random-64-bytes!!

# Включить аутентификацию (true/false)
AUTH_ENABLED=true

# Разрешённые источники CORS (через запятую)
ALLOWED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Администратор (создаётся при первом запуске)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Telegram бот для уведомлений о дашбордах
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
