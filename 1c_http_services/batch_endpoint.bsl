Функция ВыполнитьЗапросЗаказыПоставщикам(JSONПараметры)

    Товар = ПарамJSON(JSONПараметры, "item");
    Если Товар = Неопределено Тогда Товар = ""; КонецЕсли;
    Поставщик = ПарамJSON(JSONПараметры, "supplier");
    Если Поставщик = Неопределено Тогда Поставщик = ""; КонецЕсли;

    ЗапросОбъект = Новый Запрос(
    "ВЫБРАТЬ
    |    Заказы.Ссылка.Дата КАК Дата,
    |    Заказы.Номенклатура.Наименование КАК Товар,
    |    Заказы.Количество КАК Количество,
    |    Заказы.Ссылка.ДатаПоступления КАК ОжидаемаяДата,
    |    Заказы.Ссылка.Контрагент.Наименование КАК Поставщик
    |ИЗ
    |    Документ.ЗаказПоставщику.Запасы КАК Заказы
    |ГДЕ
    |    (&Товар = "" ИЛИ Заказы.Номенклатура.Наименование ПОДОБНО &ТоварП)
    |    И (&Поставщик = "" ИЛИ Заказы.Ссылка.Контрагент.Наименование ПОДОБНО &ПоставщикП)");

    ЗапросОбъект.УстановитьПараметр("Товар", "%" + Товар + "%");
    ЗапросОбъект.УстановитьПараметр("ТоварП", "%" + Товар + "%");
    ЗапросОбъект.УстановитьПараметр("Поставщик", "%" + Поставщик + "%");
    ЗапросОбъект.УстановитьПараметр("ПоставщикП", "%" + Поставщик + "%");

    Выборка = ЗапросОбъект.Выполнить().Выбрать();
    ТекущаяДатаЗнач = ТекущаяДата();

    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Стр = Новый Структура;
        Стр.Вставить("date", Формат(Выборка.Дата, "ДФ=yyyy-MM-dd"));
        Стр.Вставить("item", Выборка.Товар);
        Стр.Вставить("quantity", Выборка.Количество);
        Стр.Вставить("expected_date", Формат(Выборка.ОжидаемаяДата, "ДФ=yyyy-MM-dd"));
        Стр.Вставить("supplier", Выборка.Поставщик);
        Дней = 0;
        Если Выборка.ОжидаемаяДата < ТекущаяДатаЗнач Тогда
            Дней = (ТекущаяДатаЗнач - Выборка.ОжидаемаяДата) / 86400;
        КонецЕсли;
        Стр.Вставить("days_overdue", Цел(Дней));
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ВыполнитьЗапросДвижениеТовара(JSONПараметры)

    Товар = ПарамJSON(JSONПараметры, "item");
    Если Товар = Неопределено Тогда
        ВызватьИсключение "Не указан товар";
    КонецЕсли;
    ДатаНач = ПарамJSON(JSONПараметры, "date_from");
    Если ДатаНач = Неопределено Тогда ДатаНач = ""; КонецЕсли;
    ДатаКон = ПарамJSON(JSONПараметры, "date_to");
    Если ДатаКон = Неопределено Тогда ДатаКон = ""; КонецЕсли;

    Выборка = РегистрыНакопления.Продажи.Выбрать(, , );
    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Если Выборка.Номенклатура.Наименование <> Товар Тогда
            Продолжить;
        КонецЕсли;
        Если ЗначениеЗаполнено(ДатаНач) И Выборка.Период < Дата(СтрЗаменить(ДатаНач, "-", "")) Тогда
            Продолжить;
        КонецЕсли;
        Если ЗначениеЗаполнено(ДатаКон) И Выборка.Период > Дата(СтрЗаменить(ДатаКон, "-", "")) Тогда
            Продолжить;
        КонецЕсли;
        Стр = Новый Структура;
        Стр.Вставить("date", Формат(Выборка.Период, "ДФ=yyyy-MM-dd"));
        Стр.Вставить("incoming", 0);
        Стр.Вставить("outgoing", Выборка.Количество);
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ПрочитатьТелоЗапроса(Запрос)

    Попытка
        ТелоТекст = Запрос.ПолучитьТелоКакСтроку();
        Если ПустаяСтрока(ТелоТекст) Тогда
            Возврат Неопределено;
        КонецЕсли;
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(ТелоТекст);
        Результат = ПрочитатьJSON(Чтение);
        Чтение.Закрыть();
        Возврат Результат;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция СоздатьОтвет(КодСостояния, Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрJSON = ЗаписьJSON.Закрыть();

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрJSON);
    Возврат Ответ;

КонецФункции
