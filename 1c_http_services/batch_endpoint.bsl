Функция ОбработатьBatch(Запрос) Экспорт

    ТелоТекст = Запрос.ПолучитьТелоКакСтроку();
    Если ПустаяСтрока(ТелоТекст) Тогда
        Возврат СоздатьОтвет(400, "{""error"": ""Empty body""}");
    КонецЕсли;

    Попытка
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(ТелоТекст);
        ТелоЗапроса = ПрочитатьJSON(Чтение);
        Чтение.Закрыть();
    Исключение
        Возврат СоздатьОтвет(500, "{""error"": ""JSON parse error: """ + ОписаниеОшибки() + """}");
    КонецПопытки;

    Если ТелоЗапроса = Неопределено Тогда
        Возврат СоздатьОтвет(400, "{""error"": ""JSON returned null""}");
    КонецЕсли;

    ТипРезультата = Строка(ТипЗнч(ТелоЗапроса));

    // Проверяем, что это Соответствие или Структура
    Если ТипЗнч(ТелоЗапроса) = Тип("Соответствие") Тогда
        МассивЗапросов = ТелоЗапроса.Получить("requests");
    ИначеЕсли ТипЗнч(ТелоЗапроса) = Тип("Структура") Тогда
        МассивЗапросов = ТелоЗапроса.requests;
    Иначе
        Возврат СоздатьОтвет(400, "{""error"": ""Unexpected type: " + ТипРезультата + """}");
    КонецЕсли;

    Если МассивЗапросов = Неопределено ИЛИ ТипЗнч(МассивЗапросов) <> Тип("Массив") Тогда
        Возврат СоздатьОтвет(400, "{""error"": ""Field 'requests' must be an array, type="" + ТипРезультата");
    КонецЕсли;

    Если МассивЗапросов.Количество() > 10 Тогда
        Возврат СоздатьОтвет(400, "{""error"": ""Maximum 10 requests per batch""}");
    КонецЕсли;

    Результаты = Новый Массив;
    ОбщееВремя = 0;

    Для Каждого ЭлементЗапроса Из МассивЗапросов Цикл

        Начало = ТекущаяУниверсальнаяДатаВМиллисекундах();
        Ид = ?(ТипЗнч(ЭлементЗапроса) = Тип("Соответствие"), ЭлементЗапроса.Получить("id"), ЭлементЗапроса.id);
        Если Ид = Неопределено ИЛИ ПустаяСтрока(Ид) Тогда
            Ид = Строка(Новый УникальныйИдентификатор());
        КонецЕсли;

        Путь = ?(ТипЗнч(ЭлементЗапроса) = Тип("Соответствие"), ЭлементЗапроса.Получить("path"), ЭлементЗапроса.path);
        JSONПараметры = ?(ТипЗнч(ЭлементЗапроса) = Тип("Соответствие"), ЭлементЗапроса.Получить("params"), ЭлементЗапроса.params);

        Попытка
            Данные = ВыполнитьЗапросПоПути(Путь, JSONПараметры);
            Конец = ТекущаяУниверсальнаяДатаВМиллисекундах();
            ВремяВыполнения = Конец - Начало;
            ОбщееВремя = ОбщееВремя + ВремяВыполнения;

            РезультатЗапроса = Новый Структура;
            РезультатЗапроса.Вставить("id", Ид);
            РезультатЗапроса.Вставить("status", 200);
            РезультатЗапроса.Вставить("data", Данные);
            РезультатЗапроса.Вставить("execution_time_ms", ВремяВыполнения);
            Результаты.Добавить(РезультатЗапроса);
        Исключение
            Конец = ТекущаяУниверсальнаяДатаВМиллисекундах();
            ВремяВыполнения = Конец - Начало;
            ОбщееВремя = ОбщееВремя + ВремяВыполнения;

            РезультатЗапроса = Новый Структура;
            РезультатЗапроса.Вставить("id", Ид);
            РезультатЗапроса.Вставить("status", 500);
            РезультатЗапроса.Вставить("error", ОписаниеОшибки());
            РезультатЗапроса.Вставить("execution_time_ms", ВремяВыполнения);
            Результаты.Добавить(РезультатЗапроса);
        КонецПопытки;

    КонецЦикла;

    ОтветСтруктура = Новый Структура;
    ОтветСтруктура.Вставить("results", Результаты);
    ОтветСтруктура.Вставить("total_execution_time_ms", ОбщееВремя);
    Возврат СоздатьОтвет(200, ОтветСтруктура);

КонецФункции

Функция ВыполнитьЗапросПоПути(Путь, JSONПараметры) Экспорт

    ОтносительныйПуть = Путь;
    ОтносительныйПуть = СтрЗаменить(ОтносительныйПуть, "/hs/", "");
    ОтносительныйПуть = СтрЗаменить(ОтносительныйПуть, "/api/", "");
    ОтносительныйПуть = СтрЗаменить(ОтносительныйПуть, "//", "/");
    Если Лев(ОтносительныйПуть, 1) = "/" Тогда
        ОтносительныйПуть = Сред(ОтносительныйПуть, 2);
    КонецЕсли;

    Если ОтносительныйПуть = "stock" Тогда
        Возврат ВыполнитьЗапросОстатки(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "sales" Тогда
        Возврат ВыполнитьЗапросПродажи(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "sales/by_manager" Тогда
        Возврат ВыполнитьЗапросПродажиПоМенеджерам(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "receivables" Тогда
        Возврат ВыполнитьЗапросЗадолженность(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "purchases" Тогда
        Возврат ВыполнитьЗапросЗакупки(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "nomenclature/search" Тогда
        Возврат ВыполнитьЗапросПоискНоменклатуры(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "pricehistory" Тогда
        Возврат ВыполнитьЗапросИсторияЦен(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "purchaseorders" Тогда
        Возврат ВыполнитьЗапросЗаказыПоставщикам(JSONПараметры);
    ИначеЕсли ОтносительныйПуть = "itemmovement" Тогда
        Возврат ВыполнитьЗапросДвижениеТовара(JSONПараметры);
    Иначе
        ВызватьИсключение "Неизвестный эндпоинт: " + Путь;
    КонецЕсли;

КонецФункции

Функция ПарамJSON(Параметры, Имя)

    Если Параметры = Неопределено Тогда
        Возврат Неопределено;
    КонецЕсли;

    // Приводим Структура к Соответствие для доступа через Получить()
    Если ТипЗнч(Параметры) = Тип("Структура") Тогда
        Соотв = Новый Соответствие;
        Для Каждого КлючЗнач Из Параметры Цикл
            Соотв.Вставить(КлючЗнач.Ключ, КлючЗнач.Значение);
        КонецЦикла;
        Параметры = Соотв;
    КонецЕсли;

    Если ТипЗнч(Параметры) <> Тип("Соответствие") Тогда
        Возврат Неопределено;
    КонецЕсли;

    Возврат Параметры.Получить(Имя);

КонецФункции

Функция ВыполнитьЗапросОстатки(JSONПараметры)

    Товар = ПарамJSON(JSONПараметры, "item");
    Если Товар = Неопределено Тогда Товар = ""; КонецЕсли;
    Организация = ПарамJSON(JSONПараметры, "organization");
    Если Организация = Неопределено Тогда Организация = ""; КонецЕсли;
    МинКоличество = ПарамJSON(JSONПараметры, "min_quantity");
    Если МинКоличество = Неопределено Тогда МинКоличество = "0"; КонецЕсли;

    ЗапросОбъект = Новый Запрос(
    "ВЫБРАТЬ ПЕРВЫЕ 10
    |    Запасы.Номенклатура.Наименование КАК Номенклатура,
    |    Запасы.Организация.Наименование КАК Организация,
    |    Запасы.КоличествоОстаток КАК Количество
    |ИЗ
    |    РегистрНакопления.ЗапасыНаСкладах.Остатки КАК Запасы
    |ГДЕ
    |    Запасы.КоличествоОстаток > 0
    |    И (&Товар = "" ИЛИ Запасы.Номенклатура.Наименование ПОДОБНО &ТоварП)
    |    И (&Организация = "" ИЛИ Запасы.Организация.Наименование ПОДОБНО &ОрганизацияП)
    |    И (&МинКоличество = 0 ИЛИ Запасы.КоличествоОстаток >= &МинКоличество)
    |УПОРЯДОЧИТЬ ПО
    |    Запасы.КоличествоОстаток УБЫВ");

    ЗапросОбъект.УстановитьПараметр("Товар", Товар);
    ЗапросОбъект.УстановитьПараметр("ТоварП", "%" + Товар + "%");
    ЗапросОбъект.УстановитьПараметр("Организация", Организация);
    ЗапросОбъект.УстановитьПараметр("ОрганизацияП", "%" + Организация + "%");
    ЗапросОбъект.УстановитьПараметр("МинКоличество", Число(МинКоличество));

    Выборка = ЗапросОбъект.Выполнить().Выбрать();
    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Стр = Новый Структура;
        Стр.Вставить("item", Выборка.Номенклатура);
        Стр.Вставить("organization", Выборка.Организация);
        Стр.Вставить("quantity", Выборка.Количество);
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ВыполнитьЗапросПродажи(JSONПараметры)

    ДатаНачСтр = ПарамJSON(JSONПараметры, "date_from");
    ДатаКонСтр = ПарамJSON(JSONПараметры, "date_to");
    Товар = ПарамJSON(JSONПараметры, "item");
    Если Товар = Неопределено Тогда Товар = ""; КонецЕсли;
    Менеджер = ПарамJSON(JSONПараметры, "manager");
    Если Менеджер = Неопределено Тогда Менеджер = ""; КонецЕсли;
    ЛимитСтр = ПарамJSON(JSONПараметры, "limit");
    Если ЛимитСтр = Неопределено Тогда ЛимитСтр = "1000"; КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ДатаНачСтр) И НЕ ЗначениеЗаполнено(ДатаКонСтр) Тогда
        ДатаКон = ТекущаяДата();
        ДатаНач = ДатаКон - 30 * 86400;
    Иначе
        ДатаНач = ?(ЗначениеЗаполнено(ДатаНачСтр), Дата(СтрЗаменить(ДатаНачСтр, "-", "")), '00010101');
        ДатаКон = ?(ЗначениеЗаполнено(ДатаКонСтр), Дата(СтрЗаменить(ДатаКонСтр, "-", "")) + 86400, ТекущаяДата());
    КонецЕсли;

    Лимит = Число(ЛимитСтр);

    ТекстЗапроса =
    "ВЫБРАТЬ ПЕРВЫЕ " + Формат(Лимит, "ЧГ=") + "
    |    Продажи.Период,
    |    Продажи.Номенклатура,
    |    Продажи.Количество,
    |    Продажи.Сумма,
    |    Продажи.Ответственный,
    |    Продажи.Контрагент
    |ИЗ
    |    РегистрНакопления.Продажи КАК Продажи
    |ГДЕ
    |    Продажи.Период МЕЖДУ &ДатаНач И &ДатаКон";

    Запрос1С = Новый Запрос;
    Запрос1С.УстановитьПараметр("ДатаНач", ДатаНач);
    Запрос1С.УстановитьПараметр("ДатаКон", ДатаКон);

    Если ЗначениеЗаполнено(Товар) Тогда
        ТекстЗапроса = ТекстЗапроса + " И ПРЕДСТАВЛЕНИЕ(Продажи.Номенклатура) ПОДОБНО &ТоварШаблон";
        Запрос1С.УстановитьПараметр("ТоварШаблон", "%" + Товар + "%");
    КонецЕсли;
    Если ЗначениеЗаполнено(Менеджер) Тогда
        ТекстЗапроса = ТекстЗапроса + " И ПРЕДСТАВЛЕНИЕ(Продажи.Ответственный) ПОДОБНО &МенеджерШаблон";
        Запрос1С.УстановитьПараметр("МенеджерШаблон", "%" + Менеджер + "%");
    КонецЕсли;

    ТекстЗапроса = ТекстЗапроса + "
    |УПОРЯДОЧИТЬ ПО
    |    Продажи.Период УБЫВ";

    Запрос1С.Текст = ТекстЗапроса;
    Выборка = Запрос1С.Выполнить().Выбрать();

    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Стр = Новый Структура;
        Стр.Вставить("date", Формат(Выборка.Период, "ДФ=yyyy-MM-dd"));
        Стр.Вставить("item", Строка(Выборка.Номенклатура));
        Стр.Вставить("quantity", Выборка.Количество);
        Стр.Вставить("sum", Выборка.Сумма);
        Стр.Вставить("manager", Строка(Выборка.Ответственный));
        Стр.Вставить("client", Строка(Выборка.Контрагент));
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ВыполнитьЗапросПродажиПоМенеджерам(JSONПараметры)

    ДатаНачСтр = ПарамJSON(JSONПараметры, "date_from");
    ДатаКонСтр = ПарамJSON(JSONПараметры, "date_to");
    Менеджер = ПарамJSON(JSONПараметры, "manager");
    Если Менеджер = Неопределено Тогда Менеджер = ""; КонецЕсли;
    ЛимитСтр = ПарамJSON(JSONПараметры, "limit");
    Если ЛимитСтр = Неопределено Тогда ЛимитСтр = "1000"; КонецЕсли;

    Если НЕ ЗначениеЗаполнено(ДатаНачСтр) И НЕ ЗначениеЗаполнено(ДатаКонСтр) Тогда
        ДатаКон = ТекущаяДата();
        ДатаНач = ДатаКон - 30 * 86400;
    Иначе
        ДатаНач = ?(ЗначениеЗаполнено(ДатаНачСтр), Дата(СтрЗаменить(ДатаНачСтр, "-", "")), '00010101');
        ДатаКон = ?(ЗначениеЗаполнено(ДатаКонСтр), Дата(СтрЗаменить(ДатаКонСтр, "-", "")) + 86400, ТекущаяДата());
    КонецЕсли;

    Лимит = Число(ЛимитСтр);

    ТекстЗапроса =
    "ВЫБРАТЬ ПЕРВЫЕ " + Формат(Лимит, "ЧГ=") + "
    |    Продажи.Ответственный КАК Менеджер,
    |    СУММА(Продажи.Сумма) КАК Сумма,
    |    СУММА(Продажи.Количество) КАК Количество
    |ИЗ
    |    РегистрНакопления.Продажи КАК Продажи
    |ГДЕ
    |    Продажи.Период МЕЖДУ &ДатаНач И &ДатаКон";

    Запрос1С = Новый Запрос;
    Запрос1С.УстановитьПараметр("ДатаНач", ДатаНач);
    Запрос1С.УстановитьПараметр("ДатаКон", ДатаКон);

    Если ЗначениеЗаполнено(Менеджер) Тогда
        ТекстЗапроса = ТекстЗапроса + " И ПРЕДСТАВЛЕНИЕ(Продажи.Ответственный) ПОДОБНО &МенеджерШаблон";
        Запрос1С.УстановитьПараметр("МенеджерШаблон", "%" + Менеджер + "%");
    КонецЕсли;

    ТекстЗапроса = ТекстЗапроса + "
    |СГРУППИРОВАТЬ ПО
    |    Продажи.Ответственный
    |УПОРЯДОЧИТЬ ПО
    |    Сумма УБЫВ";

    Запрос1С.Текст = ТекстЗапроса;
    Выборка = Запрос1С.Выполнить().Выбрать();

    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Стр = Новый Структура;
        Стр.Вставить("manager", Строка(Выборка.Менеджер));
        Стр.Вставить("total_sum", Выборка.Сумма);
        Стр.Вставить("total_quantity", Выборка.Количество);
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ВыполнитьЗапросЗадолженность(JSONПараметры)

    МинСумма = ПарамJSON(JSONПараметры, "min_amount");
    Если МинСумма = Неопределено Тогда МинСумма = "0"; КонецЕсли;

    Выборка = РегистрыНакопления.РасчетыСПокупателями.Выбрать(, , );
    Клиенты = Новый Соответствие;
    Пока Выборка.Следующий() Цикл
        Сумма = Выборка.Сумма;
        Если Сумма >= 0 Тогда
            Продолжить;
        КонецЕсли;
        Клиент = Строка(Выборка.Контрагент);
        Если Не ЗначениеЗаполнено(Клиент) Тогда
            Продолжить;
        КонецЕсли;
        ТекСумма = Клиенты[Клиент];
        Если ТекСумма = Неопределено Тогда
            Клиенты[Клиент] = -Сумма;
        Иначе
            Клиенты[Клиент] = ТекСумма - Сумма;
        КонецЕсли;
    КонецЦикла;

    Массив = Новый Массив;
    Для Каждого КлючЗначение Из Клиенты Цикл
        Если ЗначениеЗаполнено(МинСумма) И КлючЗначение.Значение < Число(МинСумма) Тогда
            Продолжить;
        КонецЕсли;
        Стр = Новый Структура;
        Стр.Вставить("client", КлючЗначение.Ключ);
        Стр.Вставить("amount", КлючЗначение.Значение);
        Стр.Вставить("overdue_days", 0);
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ВыполнитьЗапросЗакупки(JSONПараметры)

    ДатаНач = ПарамJSON(JSONПараметры, "date_from");
    ДатаКон = ПарамJSON(JSONПараметры, "date_to");
    Товар = ПарамJSON(JSONПараметры, "item");
    Если Товар = Неопределено Тогда Товар = ""; КонецЕсли;
    Поставщик = ПарамJSON(JSONПараметры, "supplier");
    Если Поставщик = Неопределено Тогда Поставщик = ""; КонецЕсли;

    Выборка = РегистрыНакопления.Закупки.Выбрать(, , );
    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Если ЗначениеЗаполнено(ДатаНач) И Выборка.Период < Дата(СтрЗаменить(ДатаНач, "-", "")) Тогда
            Продолжить;
        КонецЕсли;
        Если ЗначениеЗаполнено(ДатаКон) И Выборка.Период >= Дата(СтрЗаменить(ДатаКон, "-", "")) + 86400 Тогда
            Продолжить;
        КонецЕсли;
        Если ЗначениеЗаполнено(Товар) И СтрНайти(ВРег(Выборка.Номенклатура), ВРег(Товар)) = 0 Тогда
            Продолжить;
        КонецЕсли;
        Если ЗначениеЗаполнено(Поставщик) И СтрНайти(ВРег(Выборка.Контрагент), ВРег(Поставщик)) = 0 Тогда
            Продолжить;
        КонецЕсли;
        Стр = Новый Структура;
        Стр.Вставить("date", Формат(Выборка.Период, "ДФ=yyyy-MM-dd"));
        Стр.Вставить("item", Строка(Выборка.Номенклатура));
        Стр.Вставить("quantity", Выборка.Количество);
        Стр.Вставить("sum", Выборка.Сумма);
        Стр.Вставить("supplier", Строка(Выборка.Контрагент));
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

Функция ВыполнитьЗапросПоискНоменклатуры(JSONПараметры)

    ПоискСтр = ПарамJSON(JSONПараметры, "q");
    Если ПоискСтр = Неопределено Тогда ПоискСтр = ""; КонецЕсли;
    ЛимитСтр = ПарамJSON(JSONПараметры, "limit");
    Если ЛимитСтр = Неопределено Тогда Лимит = 20; Иначе Лимит = Число(ЛимитСтр); КонецЕсли;

    Шаблон = "%" + СтрЗаменить(ПоискСтр, " ", "%") + "%";

    ТекстЗапроса =
    "ВЫБРАТЬ ПЕРВЫЕ " + Лимит + "
    |    Номенклатура.Ссылка,
    |    Номенклатура.Наименование,
    |    Номенклатура.ЕдиницаИзмерения.Наименование КАК Единица,
    |    Номенклатура.ТипНоменклатуры КАК Тип
    |ИЗ
    |    Справочник.Номенклатура КАК Номенклатура
    |ГДЕ
    |    Номенклатура.Наименование ПОДОБНО &Шаблон
    |    И Номенклатура.ПометкаУдаления = Ложь
    |УПОРЯДОЧИТЬ ПО
    |    Номенклатура.Наименование";

    ЗапросОбъект = Новый Запрос(ТекстЗапроса);
    ЗапросОбъект.УстановитьПараметр("Шаблон", Шаблон);
    Выборка = ЗапросОбъект.Выполнить().Выбрать();

    Массив = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Стр = Новый Структура;
        Стр.Вставить("ref", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
        Стр.Вставить("name", Строка(Выборка.Наименование));
        Стр.Вставить("unit", Строка(Выборка.Единица));
        Стр.Вставить("item_type", Строка(Выборка.Тип));
        Массив.Добавить(Стр);
    КонецЦикла;
    Возврат Массив;

КонецФункции

