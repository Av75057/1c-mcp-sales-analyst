// GET /hs/api/v1/documents/sales
// Получить список документов реализации с пагинацией и фильтрацией
//
// Параметры (query string):
//   date_from   — дата начала (обязательно, YYYY-MM-DD)
//   date_to     — дата окончания (обязательно, YYYY-MM-DD)
//   counterparty — фильтр по контрагенту (опционально, подстрока)
//   sum_min     — минимальная сумма (опционально)
//   sum_max     — максимальная сумма (опционально)
//   posted_only — только проведённые (по умолчанию true)
//   sort_by     — date|sum|number (по умолчанию date)
//   sort_order  — asc|desc (по умолчанию desc)
//   page        — номер страницы (по умолчанию 1)
//   page_size   — размер страницы (по умолчанию 50, макс 500)

Функция ПолучитьСписокРеализаций(Запрос) Экспорт

    // Читаем параметры
    ДатаНач = ПолучитьПараметрHTTPЗапроса(Запрос, "date_from");
    ДатаКон = ПолучитьПараметрHTTPЗапроса(Запрос, "date_to");
    КонтрагентПодстрока = ПолучитьПараметрHTTPЗапроса(Запрос, "counterparty");
    СуммаМин = ПолучитьПараметрHTTPЗапроса(Запрос, "sum_min");
    СуммаМакс = ПолучитьПараметрHTTPЗапроса(Запрос, "sum_max");
    ТолькоПроведенные = ПолучитьПараметрHTTPЗапроса(Запрос, "posted_only");
    Если ТолькоПроведенные = "" Тогда ТолькоПроведенные = "true"; КонецЕсли;
    СортПоле = ПолучитьПараметрHTTPЗапроса(Запрос, "sort_by");
    Если СортПоле = "" Тогда СортПоле = "date"; КонецЕсли;
    СортНапр = ПолучитьПараметрHTTPЗапроса(Запрос, "sort_order");
    Если СортНапр = "" Тогда СортНапр = "desc"; КонецЕсли;
    СтраницаСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "page");
    Если СтраницаСтр = "" Тогда СтраницаСтр = "1"; КонецЕсли;
    РазмерСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "page_size");
    Если РазмерСтр = "" Тогда РазмерСтр = "50"; КонецЕсли;

    // Валидация
    Если ПустаяСтрока(ДатаНач) ИЛИ ПустаяСтрока(ДатаКон) Тогда
        Возврат Ошибка400("Параметры date_from и date_to обязательны");
    КонецЕсли;

    Попытка
        ДатаНачала = Дата(СтрЗаменить(ДатаНач, "-", ""));
        ДатаОкончания = Дата(СтрЗаменить(ДатаКон, "-", ""));
    Исключение
        Возврат Ошибка400("Неверный формат даты. Используйте YYYY-MM-DD");
    КонецПопытки;

    Страница = Число(СтраницаСтр);
    РазмерСтраницы = Число(РазмерСтр);
    Если РазмерСтраницы > 500 Тогда РазмерСтраницы = 500; КонецЕсли;
    Если РазмерСтраницы < 1 Тогда РазмерСтраницы = 50; КонецЕсли;
    Если Страница < 1 Тогда Страница = 1; КонецЕсли;
    Смещение = (Страница - 1) * РазмерСтраницы;

    // Проверяем поле сортировки (безопасность)
    ДопустимыеПоля = Новый Соответствие;
    ДопустимыеПоля.Вставить("date", "Реализация.Дата");
    ДопустимыеПоля.Вставить("sum", "Реализация.СуммаДокумента");
    ДопустимыеПоля.Вставить("number", "Реализация.Номер");
    ПолеСортировки = ДопустимыеПоля.Получить(СортПоле);
    Если ПолеСортировки = Неопределено Тогда ПолеСортировки = "Реализация.Дата"; КонецЕсли;

    Направление = ?(ВРег(СортНапр) = "ASC", "ASC", "DESC");

    // Формируем запрос
    ЗапросОбъект = Новый Запрос;
    ЗапросОбъект.Текст =
    "ВЫБРАТЬ РАЗРЕШЕННЫЕ
    |    Реализация.Ссылка КАК СсылкаДокумента,
    |    Реализация.Номер КАК НомерДокумента,
    |    Реализация.Дата КАК ДатаДокумента,
    |    Реализация.Контрагент.Наименование КАК КонтрагентИмя,
    |    Реализация.Контрагент.Ссылка КАК КонтрагентСсылка,
    |    Реализация.Контрагент.ИНН КАК ИНН,
    |    Реализация.СуммаДокумента КАК СуммаДокумента,
    |    Реализация.Валюта.Код КАК КодВалюты,
    |    Реализация.Проведен КАК Проведен,
    |    Реализация.ПометкаУдаления КАК ПометкаУдаления,
    |    Реализация.Комментарий КАК Комментарий
    |ИЗ
    |    Документ.РеализацияТоваровУслуг КАК Реализация
    |ГДЕ
    |    Реализация.Дата МЕЖДУ &ДатаНачала И &ДатаОкончания
    |    И (&ТолькоПроведен = ЛОЖЬ ИЛИ Реализация.Проведен)
    |    И НЕ Реализация.ПометкаУдаления";

    ЗапросОбъект.УстановитьПараметр("ДатаНачала", ДатаНачала);
    ЗапросОбъект.УстановитьПараметр("ДатаОкончания", ДатаОкончания + 86400);
    ЗапросОбъект.УстановитьПараметр("ТолькоПроведен", ВРег(ТолькоПроведенные) = "TRUE");

    Если ЗначениеЗаполнено(КонтрагентПодстрока) Тогда
        ЗапросОбъект.Текст = ЗапросОбъект.Текст + "
        |    И Реализация.Контрагент.Наименование ПОДОБНО &КонтрагентШаблон";
        ЗапросОбъект.УстановитьПараметр("КонтрагентШаблон", "%" + КонтрагентПодстрока + "%");
    КонецЕсли;

    Если ЗначениеЗаполнено(СуммаМин) Тогда
        ЗапросОбъект.Текст = ЗапросОбъект.Текст + "
        |    И Реализация.СуммаДокумента >= &СуммаМин";
        ЗапросОбъект.УстановитьПараметр("СуммаМин", Число(СуммаМин));
    КонецЕсли;

    Если ЗначениеЗаполнено(СуммаМакс) Тогда
        ЗапросОбъект.Текст = ЗапросОбъект.Текст + "
        |    И Реализация.СуммаДокумента <= &СуммаМакс";
        ЗапросОбъект.УстановитьПараметр("СуммаМакс", Число(СуммаМакс));
    КонецЕсли;

    ЗапросОбъект.Текст = ЗапросОбъект.Текст + "
    |УПОРЯДОЧИТЬ ПО " + ПолеСортировки + " " + Направление;

    // Сначала получаем общее количество
    ЗапросОбъект.Текст = ЗапросОбъект.Текст + "
    |АВТОУПОРЯДОЧИВАНИЕ";

    Результат = ЗапросОбъект.Выполнить();
    ОбщееКоличество = Результат.Количество();

    // Ограничиваем запрос для пагинации
    ЗапросОбъект.Текст = ЗапросОбъект.Текст + "
    |ИТОГИ КОЛИЧЕСТВО (СсылкаДокумента) КАК Всего";

    Выборка = ЗапросОбъект.Выполнить().Выбрать();
    МассивДокументов = Новый Массив;
    Пропущено = 0;

    Пока Выборка.Следующий() Цикл
        Пропущено = Пропущено + 1;
        Если Пропущено <= Смещение Тогда
            Продолжить;
        КонецЕсли;
        Если МассивДокументов.Количество() >= РазмерСтраницы Тогда
            Прервать;
        КонецЕсли;

        // Считаем количество строк в документе
        КоличествоСтрок = 0;
        Попытка
            ЗапросСтрок = Новый Запрос(
            "ВЫБРАТЬ КОЛИЧЕСТВО(Товары.НомерСтроки) КАК КоличествоСтрок
            |ИЗ Документ.РеализацияТоваровУслуг.Товары КАК Товары
            |ГДЕ Товары.Ссылка = &Ссылка");
            ЗапросСтрок.УстановитьПараметр("Ссылка", Выборка.СсылкаДокумента);
            КоличествоСтрок = ЗапросСтрок.Выполнить().Выгрузить()[0].КоличествоСтрок;
        Исключение
            КоличествоСтрок = 0;
        КонецПопытки;

        Док = Новый Структура;
        Док.Вставить("id", Строка(Выборка.СсылкаДокумента.УникальныйИдентификатор()));
        Док.Вставить("number", Выборка.НомерДокумента);
        Док.Вставить("date", Формат(Выборка.ДатаДокумента, "ДФ=yyyy-MM-dd'T'HH:mm:ss"));
        Док.Вставить("counterparty", Новый Структура(
            "name, id, inn",
            Выборка.КонтрагентИмя,
            Строка(Выборка.КонтрагентСсылка.УникальныйИдентификатор()),
            ?(ЗначениеЗаполнено(Выборка.ИНН), Выборка.ИНН, "")
        ));
        Док.Вставить("sum", Выборка.СуммаДокумента);
        Док.Вставить("currency", ?(ЗначениеЗаполнено(Выборка.КодВалюты), Выборка.КодВалюты, "RUB"));
        Док.Вставить("posted", Выборка.Проведен);
        Док.Вставить("deleted", Выборка.ПометкаУдаления);
        Док.Вставить("comment", ?(ЗначениеЗаполнено(Выборка.Комментарий), Выборка.Комментарий, ""));
        Док.Вставить("items_count", КоличествоСтрок);
        МассивДокументов.Добавить(Док);
    КонецЦикла;

    ВсегоСтраниц = Цел(ОбщееКоличество / РазмерСтраницы);
    Если ОбщееКоличество % РазмерСтраницы > 0 Тогда
        ВсегоСтраниц = ВсегоСтраниц + 1;
    КонецЕсли;

    ОтветСтруктура = Новый Структура;
    ОтветСтруктура.Вставить("documents", МассивДокументов);
    ОтветСтруктура.Вставить("pagination", Новый Структура(
        "page, page_size, total_count, total_pages",
        Страница, РазмерСтраницы, ОбщееКоличество, ВсегоСтраниц
    ));

    Возврат СоздатьОтвет(200, ОтветСтруктура);

КонецФункции

Функция СоздатьОтвет(КодСостояния, Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрJSON = ЗаписьJSON.Закрыть();

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрJSON);
    Возврат Ответ;

КонецФункции

Функция Ошибка400(Текст)

    Возврат СоздатьОтвет(400, "{""error"": """ + Текст + """}");

КонецФункции
