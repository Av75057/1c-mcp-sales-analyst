Функция ПолучитьСписокРеализаций(Запрос) Экспорт

    ДатаНачСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "date_from");
    ДатаКонСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "date_to");

    Если ПустаяСтрока(ДатаНачСтр) ИЛИ ПустаяСтрока(ДатаКонСтр) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "date_from и date_to обязательны"));
    КонецЕсли;

    ДатаНач = Дата(СтрЗаменить(ДатаНачСтр, "-", ""));
    ДатаКон = Дата(СтрЗаменить(ДатаКонСтр, "-", ""));

    Попытка
        ЗапросОбъект = Новый Запрос(
        "ВЫБРАТЬ ПЕРВЫЕ 50
        |    Продажи.Регистратор КАК Ссылка,
        |    МАКСИМУМ(Продажи.Период) КАК Дата,
        |    МАКСИМУМ(Продажи.Контрагент) КАК Клиент,
        |    СУММА(Продажи.Сумма) КАК Сумма
        |ИЗ
        |    РегистрНакопления.Продажи КАК Продажи
        |ГДЕ
        |    Продажи.Период МЕЖДУ &ДатаНач И &ДатаКон
        |СГРУППИРОВАТЬ ПО
        |    Продажи.Регистратор
        |УПОРЯДОЧИТЬ ПО
        |    Дата УБЫВ");

        ЗапросОбъект.УстановитьПараметр("ДатаНач", ДатаНач);
        ЗапросОбъект.УстановитьПараметр("ДатаКон", ДатаКон + 86400);

        Выборка = ЗапросОбъект.Выполнить().Выбрать();

        Массив = Новый Массив;
        Пока Выборка.Следующий() Цикл
            Стр = Новый Структура;
            Стр.Вставить("id", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
            Стр.Вставить("number", Строка(Выборка.Ссылка.Номер));
            Стр.Вставить("date", Формат(Выборка.Дата, "ДФ=yyyy-MM-dd'T'HH:mm:ss"));
            Стр.Вставить("counterparty", Строка(Выборка.Клиент));
            Стр.Вставить("sum", Выборка.Сумма);
            Стр.Вставить("posted", Выборка.Ссылка.Проведен);
            Массив.Добавить(Стр);
        КонецЦикла;

        Возврат СоздатьОтвет(200, Новый Структура("documents", Массив));

    Исключение
        Возврат СоздатьОтвет(500, Новый Структура("error", ОписаниеОшибки()));
    КонецПопытки;

КонецФункции
