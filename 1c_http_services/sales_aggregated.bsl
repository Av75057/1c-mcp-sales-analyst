// GET /inventory/stock?min_quantity=1
// Возвращает остатки: только товары с количеством > 0

Функция ОстаткиТоваров(Параметры) Экспорт

    МинКоличество = Число(Параметры.Получить("min_quantity"));
    Если МинКоличество = 0 Тогда МинКоличество = 1; КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Запасы.Номенклатура КАК Товар,
    |    Запасы.Склад КАК Склад,
    |    Запасы.КоличествоОстаток КАК Количество,
    |    Запасы.СуммаОстаток КАК Сумма
    |ИЗ
    |    РегистрНакопления.Запасы.Остатки(, ) КАК Запасы
    |ГДЕ
    |    Запасы.КоличествоОстаток > &МинКоличество";

    Запрос.УстановитьПараметр("МинКоличество", МинКоличество);

    Результат = Запрос.Выполнить().Выгрузить();

    МассивТоваров = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        МассивТоваров.Добавить(Новый Структура(
            "product, warehouse, quantity, amount",
            Строка.Товар,
            Строка.Склад,
            Строка.Количество,
            Строка.Сумма
        ));
    КонецЦикла;

    Возврат МассивТоваров;

КонецФункции


// GET /sales/slow-moving?date_from=...&date_to=...
// Возвращает неликвиды: товары с остатком > 0, по которым не было продаж за период

Функция Неликвиды(Параметры) Экспорт

    ДатаНачала = Параметры.Получить("date_from");
    ДатаОкончания = Параметры.Получить("date_to");

    Если ПустаяСтрока(ДатаОкончания) Тогда
        ДатаОкончания = ТекущаяДата();
    КонецЕсли;

    // По умолчанию смотрим за 90 дней
    Если ПустаяСтрока(ДатаНачала) Тогда
        ДатаНачала = ТекущаяДата() - 90 * 86400;
    КонецЕсли;

    // Товары с остатком, но без продаж за период
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Запасы.Номенклатура КАК Товар,
    |    Запасы.КоличествоОстаток КАК Количество,
    |    Запасы.СуммаОстаток КАК СуммаОстатка,
    |    &ДатаОкончания - МАКСИМУМ(Продажи.Период) КАК ДнейСПоследнейПродажи
    |ИЗ
    |    РегистрНакопления.Запасы.Остатки(, ) КАК Запасы
    |        ЛЕВОЕ СОЕДИНЕНИЕ РегистрНакопления.Продажи.Обороты(, &ДатаНачала, &ДатаОкончания, , ) КАК Продажи
    |        ПО Запасы.Номенклатура = Продажи.Номенклатура
    |ГДЕ
    |    Запасы.КоличествоОстаток > 0
    |    И Продажи.КоличествоОборот ЕСТЬ NULL
    |СГРУППИРОВАТЬ ПО
    |    Запасы.Номенклатура,
    |    Запасы.КоличествоОстаток,
    |    Запасы.СуммаОстаток
    |УПОРЯДОЧИТЬ ПО
    |    СуммаОстатка УБЫВ";

    Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

    Результат = Запрос.Выполнить().Выгрузить();

    МассивНеликвидов = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        МассивНеликвидов.Добавить(Новый Структура(
            "product, stock_quantity, stock_value, days_since_last_sale",
            Строка.Товар,
            Строка.Количество,
            Строка.СуммаОстатка,
            Строка.ДнейСПоследнейПродажи
        ));
    КонецЦикла;

    Возврат МассивНеликвидов;

КонецФункции


// GET /sales/with-docs?date_from=...&date_to=...&limit=1000
// Возвращает записи регистра продаж с номером документа-регистратора

Функция ПродажиСНомерамиДокументов(Параметры) Экспорт

    ДатаНачала = Параметры.Получить("date_from");
    ДатаОкончания = Параметры.Получить("date_to");
    Лимит = Число(Параметры.Получить("limit"));
    Если Лимит = 0 Тогда Лимит = 1000; КонецЕсли;

    Если ПустаяСтрока(ДатаНачала) Тогда
        ДатаНачала = НачалоМесяца(ТекущаяДата());
    КонецЕсли;
    Если ПустаяСтрока(ДатаОкончания) Тогда
        ДатаОкончания = ТекущаяДата();
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ &Лимит
    |    Продажи.Период КАК Период,
    |    Продажи.Номенклатура КАК Номенклатура,
    |    Продажи.Количество КАК Количество,
    |    Продажи.Сумма КАК Сумма,
    |    Продажи.Регистратор.Номер КАК НомерДокумента,
    |    Продажи.Контрагент КАК Контрагент,
    |    Продажи.Ответственный КАК Менеджер
    |ИЗ
    |    РегистрНакопления.Продажи КАК Продажи
    |ГДЕ
    |    Продажи.Период МЕЖДУ &ДатаНачала И &ДатаОкончания
    |УПОРЯДОЧИТЬ ПО
    |    Продажи.Период УБЫВ";

    Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
    Запрос.УстановитьПараметр("Лимит", Лимит);

    Результат = Запрос.Выполнить().Выгрузить();

    МассивСтрок = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        МассивСтрок.Добавить(Новый Структура(
            "date, nomenclature, quantity, sum, document_number, client, manager",
            Строка.Период,
            Строка.Номенклатура,
            Строка.Количество,
            Строка.Сумма,
            Строка.НомерДокумента,
            Строка.Контрагент,
            Строка.Менеджер
        ));
    КонецЦикла;

    Возврат МассивСтрок;

КонецФункции
