// Оптимизированные запросы для агрегации на стороне 1С
// HTTP-сервисы, возвращающие только агрегированные данные (топ-N)
// вместо всех документов продаж.
//
// Установка: разместить в модуле HTTPСервисАналитика

// GET /sales/summary?date_from=...&date_to=...
// Возвращает сводку: total_sales, total_orders, avg_order, dates
//
// Запрос:
// ВЫБРАТЬ
//     СУММА(Продажи.СуммаОборот) КАК ОбщаяСуммаПродаж,
//     КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Продажи.Регистратор) КАК КоличествоЗаказов,
//     МИНИМУМ(Продажи.Период) КАК МинДата,
//     МАКСИМУМ(Продажи.Период) КАК МаксДата
// ИЗ
//     РегистрНакопления.Продажи.Обороты(, &ДатаНачала, &ДатаОкончания, , ) КАК Продажи

Функция ПродажиСводка(Параметры) Экспорт

    ДатаНачала = Параметры.Получить("date_from");
    ДатаОкончания = Параметры.Получить("date_to");

    Если ПустаяСтрока(ДатаНачала) Тогда
        ДатаНачала = НачалоМесяца(ТекущаяДата());
    КонецЕсли;

    Если ПустаяСтрока(ДатаОкончания) Тогда
        ДатаОкончания = ТекущаяДата();
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    СУММА(Продажи.СуммаОборот) КАК ОбщаяСуммаПродаж,
    |    КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Продажи.Регистратор) КАК КоличествоЗаказов,
    |    МИНИМУМ(Продажи.Период) КАК МинДата,
    |    МАКСИМУМ(Продажи.Период) КАК МаксДата
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(, &ДатаНачала, &ДатаОкончания, , ) КАК Продажи";

    Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

    Результат = Запрос.Выполнить().Выгрузить();

    Если Результат.Количество() = 0 Тогда
        Возврат Новый Структура("total_sales, total_orders, avg_order, dates", 0, 0, 0, Новый Структура("min", ДатаНачала, "max", ДатаОкончания));
    КонецЕсли;

    СтрокаРезультата = Результат[0];
    ОбщаяСумма = СтрокаРезультата.ОбщаяСуммаПродаж;
    КоличествоЗаказов = СтрокаРезультата.КоличествоЗаказов;

    СреднийЧек = 0;
    Если КоличествоЗаказов > 0 Тогда
        СреднийЧек = ОбщаяСумма / КоличествоЗаказов;
    КонецЕсли;

    Возврат Новый Структура(
        "total_sales, total_orders, avg_order, dates",
        ОбщаяСумма,
        КоличествоЗаказов,
        СреднийЧек,
        Новый Структура("min", СтрокаРезультата.МинДата, "max", СтрокаРезультата.МаксДата)
    );

КонецФункции


// GET /sales/by-product?date_from=...&date_to=...&limit=20
// Возвращает топ-N товаров по сумме продаж
//
// Запрос:
// ВЫБРАТЬ ПЕРВЫЕ &Лимит
//     Продажи.Номенклатура КАК Товар,
//     СУММА(Продажи.КоличествоОборот) КАК Количество,
//     СУММА(Продажи.СуммаОборот) КАК Сумма,
//     КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Продажи.Регистратор) КАК Заказов
// ИЗ
//     РегистрНакопления.Продажи.Обороты(, &ДатаНачала, &ДатаОкончания, , ) КАК Продажи
// СГРУППИРОВАТЬ ПО
//     Продажи.Номенклатура
// УПОРЯДОЧИТЬ ПО
//     Сумма УБЫВ

Функция ПродажиПоТоварам(Параметры) Экспорт

    ДатаНачала = Параметры.Получить("date_from");
    ДатаОкончания = Параметры.Получить("date_to");
    Лимит = Число(Параметры.Получить("limit"));
    Если Лимит = 0 Тогда Лимит = 20; КонецЕсли;

    Если ПустаяСтрока(ДатаНачала) Тогда
        ДатаНачала = НачалоМесяца(ТекущаяДата());
    КонецЕсли;

    Если ПустаяСтрока(ДатаОкончания) Тогда
        ДатаОкончания = ТекущаяДата();
    КонецЕсли;

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ ПЕРВЫЕ &Лимит
    |    Продажи.Номенклатура КАК Товар,
    |    СУММА(Продажи.КоличествоОборот) КАК Количество,
    |    СУММА(Продажи.СуммаОборот) КАК Сумма,
    |    КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Продажи.Регистратор) КАК Заказов
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(, &ДатаНачала, &ДатаОкончания, , ) КАК Продажи
    |СГРУППИРОВАТЬ ПО
    |    Продажи.Номенклатура
    |УПОРЯДОЧИТЬ ПО
    |    Сумма УБЫВ";

    Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);
    Запрос.УстановитьПараметр("Лимит", Лимит);

    Результат = Запрос.Выполнить().Выгрузить();

    МассивТоваров = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        МассивТоваров.Добавить(Новый Структура(
            "product, quantity, amount, orders_count",
            Строка.Товар,
            Строка.Количество,
            Строка.Сумма,
            Строка.Заказов
        ));
    КонецЦикла;

    Возврат МассивТоваров;

КонецФункции


