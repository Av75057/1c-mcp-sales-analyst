// Материализованная витрина продаж по дням
//
// Регистр сведений: ВитринаПродажПоДням
// Измерения:
//   Период (дата, день)
//   Номенклатура (справочник.Номенклатура)
// Ресурсы:
//   Количество (число, 15.3)
//   Сумма (число, 15.2)
//   Себестоимость (число, 15.2)
//   Прибыль (число, 15.2)
//
// Обновление: фоновое задание каждые 15 минут + подписка на событие Проведение документа

// ---- Заполнение витрины (выполняется в фоновом задании) ----

Процедура ЗаполнитьВитринуПродажПоДням() Экспорт

    НачалоПериода = ТекущаяДата() - 365 * 86400; // За последний год
    КонецПериода = ТекущаяДата();

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Продажи.Период КАК Период,
    |    Продажи.Номенклатура КАК Номенклатура,
    |    СУММА(Продажи.КоличествоОборот) КАК Количество,
    |    СУММА(Продажи.СуммаОборот) КАК Сумма,
    |    СУММА(Продажи.СебестоимостьОборот) КАК Себестоимость,
    |    СУММА(Продажи.СуммаОборот - Продажи.СебестоимостьОборот) КАК Прибыль
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(, &НачалоПериода, &КонецПериода, , ) КАК Продажи
    |СГРУППИРОВАТЬ ПО
    |    Продажи.Период,
    |    Продажи.Номенклатура
    |УПОРЯДОЧИТЬ ПО
    |    Период";

    Запрос.УстановитьПараметр("НачалоПериода", НачалоПериода);
    Запрос.УстановитьПараметр("КонецПериода", КонецПериода);

    Выборка = Запрос.Выполнить().Выбрать();

    НаборЗаписей = РегистрыСведений.ВитринаПродажПоДням.СоздатьНаборЗаписей();
    НаборЗаписей.Отбор.Период.Установить(НачалоПериода, КонецПериода);
    НаборЗаписей.Прочитать();

    Пока Выборка.Следующий() Цикл

        Запись = НаборЗаписей.Добавить();
        Запись.Период = Выборка.Период;
        Запись.Номенклатура = Выборка.Номенклатура;
        Запись.Количество = Выборка.Количество;
        Запись.Сумма = Выборка.Сумма;
        Запись.Себестоимость = Выборка.Себестоимость;
        Запись.Прибыль = Выборка.Прибыль;

    КонецЦикла;

    НаборЗаписей.Записать();

КонецПроцедуры


// ---- Подписка на событие (выполняется при проведении документа продажи) ----

Процедура ОбновитьВитринуПриПроведении(Источник, Отказ) Экспорт

    Если Не Источник.Проведен Тогда
        Возврат;
    КонецЕсли;

    // Обновляем витрину для даты документа
    НаборЗаписей = РегистрыСведений.ВитринаПродажПоДням.СоздатьНаборЗаписей();
    НаборЗаписей.Отбор.Период.Установить(Источник.Дата, Источник.Дата);
    НаборЗаписей.Прочитать();

    // Удаляем старые записи за этот день
    НаборЗаписей.Очистить();

    // Собираем продажи за этот день
    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Товары.Номенклатура КАК Номенклатура,
    |    СУММА(Товары.Количество) КАК Количество,
    |    СУММА(Товары.Сумма) КАК Сумма,
    |    СУММА(Товары.СуммаСебестоимости) КАК Себестоимость
    |ИЗ
    |    Документ.РеализацияТоваровУслуг.Товары КАК Товары
    |ГДЕ
    |    Товары.Ссылка = &Ссылка
    |СГРУППИРОВАТЬ ПО
    |    Товары.Номенклатура";

    Запрос.УстановитьПараметр("Ссылка", Источник.Ссылка);

    Результат = Запрос.Выполнить().Выгрузить();

    Для Каждого Строка Из Результат Цикл
        Запись = НаборЗаписей.Добавить();
        Запись.Период = Источник.Дата;
        Запись.Номенклатура = Строка.Номенклатура;
        Запись.Количество = Строка.Количество;
        Запись.Сумма = Строка.Сумма;
        Запись.Себестоимость = Строка.Себестоимость;
        Запись.Прибыль = Строка.Сумма - Строка.Себестоимость;
    КонецЦикла;

    НаборЗаписей.Записать();

КонецПроцедуры


// ---- Запрос к витрине (выполняется за < 0.1 сек вместо 30 сек) ----

Функция ПродажиИзВитрины(ДатаНачала, ДатаОкончания) Экспорт

    Запрос = Новый Запрос;
    Запрос.Текст =
    "ВЫБРАТЬ
    |    Период,
    |    Номенклатура,
    |    СУММА(Количество) КАК Количество,
    |    СУММА(Сумма) КАК Сумма,
    |    СУММА(Прибыль) КАК Прибыль
    |ИЗ
    |    РегистрСведений.ВитринаПродажПоДням
    |ГДЕ
    |    Период МЕЖДУ &ДатаНачала И &ДатаОкончания
    |СГРУППИРОВАТЬ ПО
    |    Период, Номенклатура";

    Запрос.УстановитьПараметр("ДатаНачала", ДатаНачала);
    Запрос.УстановитьПараметр("ДатаОкончания", ДатаОкончания);

    Результат = Запрос.Выполнить().Выгрузить();

    МассивПродаж = Новый Массив;
    Для Каждого Строка Из Результат Цикл
        МассивПродаж.Добавить(Новый Структура(
            "date, nomenclature, quantity, sum, profit",
            Строка.Период,
            Строка.Номенклатура,
            Строка.Количество,
            Строка.Сумма,
            Строка.Прибыль
        ));
    КонецЦикла;

    Возврат МассивПродаж;

КонецФункции


// ---- Фоновое задание для периодического обновления витрины ----

Процедура ОбновитьВитринуФоновоеЗадание() Экспорт

    Попытка
        ЗаполнитьВитринуПродажПоДням();
        ЗаписатьВЖурналРегистрации("Витрина продаж", УровеньЖурналаРегистрации.Информация,
            "Витрина продаж по дням обновлена", "Обновление витрины завершено успешно");
    Исключение
        ЗаписатьВЖурналРегистрации("Витрина продаж", УровеньЖурналаРегистрации.Ошибка,
            "Ошибка обновления витрины", ОписаниеОшибки());
    КонецПопытки;

КонецПроцедуры


