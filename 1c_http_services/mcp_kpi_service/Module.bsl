////////////////////////////////////////////////////////////////////////////////
// HTTP-сервис: mcp_kpi_service
// Метод: POST /hs/kpi/executive
// Возвращает агрегированные KPI для панели руководителя:
// выручка, прибыль, количество заказов, маржа, топ-менеджер, спарклайны.
//
// Вход (JSON body):
//   date_from          - начало текущего периода
//   date_to            - конец текущего периода
//   prev_date_from     - начало предыдущего периода
//   prev_date_to       - конец предыдущего периода
//   organization       - GUID организации (пустая строка = все)
//   include_sparklines - true/false
//
// Выход: массив строк с полями type, revenue, profit, orders_count,
//        margin_percent, top_manager_name, top_manager_revenue
//        Для type=sparkline: date, revenue
////////////////////////////////////////////////////////////////////////////////

Функция GetExecutiveKPI(Запрос) Экспорт

    Попытка
        Тело = Запрос.ПолучитьТелоКакСтроку();
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(Тело);
        Параметры = ПрочитатьJSON(Чтение);
        Чтение.Закрыть();

        Если Параметры = Неопределено Тогда
            Возврат СоздатьОтвет(400, Новый Структура("error", "Empty JSON body"));
        КонецЕсли;

        Результат = ВыполнитьKPIЗапрос(
            Параметры.date_from,
            Параметры.date_to,
            Параметры.prev_date_from,
            Параметры.prev_date_to,
            Параметры.organization,
            Параметры.include_sparklines);

        Возврат СоздатьОтвет(200, Результат);

    Исключение
        Ошибка = Новый Структура("error", ОписаниеОшибки());
        Возврат СоздатьОтвет(500, Ошибка);
    КонецПопытки;

КонецФункции


Функция ВыполнитьKPIЗапрос(ДатаНачТек, ДатаКонТек, ДатаНачПред, ДатаКонПред, Организация, ВклСпарклайны)

    ЧастиЗапроса = Новый Массив;

    // ---- Блок 1: текущий период ----
    ТекстТекущий =
    "ВЫБРАТЬ
    |    ""current"" КАК Тип,
    |    СУММА(Тек.СуммаОборот) КАК Выручка,
    |    СУММА(Тек.СуммаОборот - Тек.СебестоимостьОборот) КАК Прибыль,
    |    КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Тек.Регистратор) КАК КолвоЗаказов
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(, &ДатаНачТек, &ДатаКонТек, , ) КАК Тек
    |ГДЕ
    |    (&Организация = """") ИЛИ (Тек.Организация = &Организация)";

    ЧастиЗапроса.Добавить(ТекстТекущий);

    // ---- Блок 2: предыдущий период ----
    ТекстПредыдущий =
    "ВЫБРАТЬ
    |    ""previous"" КАК Тип,
    |    СУММА(Пред.СуммаОборот) КАК Выручка,
    |    СУММА(Пред.СуммаОборот - Пред.СебестоимостьОборот) КАК Прибыль,
    |    КОЛИЧЕСТВО(РАЗЛИЧНЫЕ Пред.Регистратор) КАК КолвоЗаказов
    |ИЗ
    |    РегистрНакопления.Продажи.Обороты(, &ДатаНачПред, &ДатаКонПред, , ) КАК Пред
    |ГДЕ
    |    (&Организация = """") ИЛИ (Пред.Организация = &Организация)";

    ЧастиЗапроса.Добавить(ТекстПредыдущий);

    // ---- Блок 3: спарклайн-данные (посуточная группировка) ----
    Если ВклСпарклайны Тогда
        ТекстСпарклайн =
        "ВЫБРАТЬ
        |    ""sparkline"" КАК Тип,
        |    СУММА(Сп.СуммаОборот) КАК Выручка,
        |    0 КАК Прибыль,
        |    0 КАК КолвоЗаказов,
        |    ВЫРАЗИТЬ(Сп.Период КАК ДАТА) КАК ДатаГрупп
        |ИЗ
        |    РегистрНакопления.Продажи.Обороты(, &ДатаНачТек, &ДатаКонТек, , ) КАК Сп
        |ГДЕ
        |    (&Организация = """") ИЛИ (Сп.Организация = &Организация)
        |СГРУППИРОВАТЬ ПО
        |    ВЫРАЗИТЬ(Сп.Период КАК ДАТА)";

        ЧастиЗапроса.Добавить(ТекстСпарклайн);
    КонецЕсли;

    // Склеиваем через UNION ALL
    ОбщийТекст = "";
    Для Инд = 0 По ЧастиЗапроса.Количество() - 1 Цикл
        Если Инд > 0 Тогда
            ОбщийТекст = ОбщийТекст + "
            |ОБЪЕДИНИТЬ ВСЕ
            |";
        КонецЕсли;
        ОбщийТекст = ОбщийТекст + ЧастиЗапроса[Инд];
    КонецЦикла;

    Запрос1С = Новый Запрос;
    Запрос1С.Текст = ОбщийТекст;

    Запрос1С.УстановитьПараметр("ДатаНачТек",  ДатаНачТек);
    Запрос1С.УстановитьПараметр("ДатаКонТек",  ДатаКонТек);
    Запрос1С.УстановитьПараметр("ДатаНачПред", ДатаНачПред);
    Запрос1С.УстановитьПараметр("ДатаКонПред", ДатаКонПред);
    Запрос1С.УстановитьПараметр("Организация", ?(ЗначениеЗаполнено(Организация), Организация, ""));

    Выборка = Запрос1С.Выполнить().Выбрать();

    Результат = Новый Массив;
    Пока Выборка.Следующий() Цикл
        Строка = Новый Структура;
        Строка.Вставить("type",              СокрЛП(Выборка.Тип));
        Строка.Вставить("revenue",           Выборка.Выручка);
        Строка.Вставить("profit",            Выборка.Прибыль);
        Строка.Вставить("orders_count",      Выборка.КолвоЗаказов);

        Если Выборка.Тип = "sparkline" Тогда
            Строка.Вставить("date", Формат(Выборка.ДатаГрупп, "ДФ=yyyy-MM-dd"));
        Иначе
            Маржа = 0;
            Если Выборка.Выручка <> 0 Тогда
                Маржа = (Выборка.Прибыль / Выборка.Выручка) * 100;
            КонецЕсли;
            Строка.Вставить("margin_percent",    Окр(Маржа, 1));
            Строка.Вставить("top_manager_name",    "");
            Строка.Вставить("top_manager_revenue", 0);
        КонецЕсли;

        Результат.Добавить(Строка);
    КонецЦикла;

    // Если данных нет — возвращаем строки-заглушки
    Если Результат.Количество() = 0 Тогда
        Типы = Новый Массив;
        Типы.Добавить("current");
        Типы.Добавить("previous");
        Для Каждого ТипСтр Из Типы Цикл
            Строка = Новый Структура;
            Строка.Вставить("type", ТипСтр);
            Строка.Вставить("revenue", 0);
            Строка.Вставить("profit", 0);
            Строка.Вставить("orders_count", 0);
            Строка.Вставить("margin_percent", 0);
            Строка.Вставить("top_manager_name", "");
            Строка.Вставить("top_manager_revenue", 0);
            Результат.Добавить(Строка);
        КонецЦикла;
    КонецЕсли;

    Возврат Результат;

КонецФункции


Функция СоздатьОтвет(КодСостояния, Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрJSON = ЗаписьJSON.Закрыть();

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрJSON);
    Возврат Ответ;

КонецФункции
