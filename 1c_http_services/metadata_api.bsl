// HTTP-сервис: Metadata API
// GET /hs/metadata/config      — паспорт базы
// GET /hs/metadata/describe    — список объектов метаданных
// GET /hs/metadata/structure   — структура объекта

Функция ConfigGET(Запрос) Экспорт

    Результат = Новый Структура;
    Результат.Вставить("name", Метаданные.Имя);
    Результат.Вставить("configuration", Метаданные.Имя);
    Результат.Вставить("version", Метаданные.Версия);
    Результат.Вставить("mode", "production");
    Результат.Вставить("platform_version", Метаданные.Версия);

    Возврат СоздатьОтвет(200, Результат);

КонецФункции

Функция DescribeGET(Запрос) Экспорт

    ТипОбъекта = ПолучитьПараметрHTTPЗапроса(Запрос, "type");
    Поиск = ПолучитьПараметрHTTPЗапроса(Запрос, "search");

    МассивОбъектов = Новый Массив;

    Если ТипОбъекта = "" ИЛИ ТипОбъекта = "Catalog" Тогда
        Для Каждого Спр Из Метаданные.Справочники Цикл
            Если ЗначениеЗаполнено(Поиск) И СтрНайти(ВРег(Спр.Имя), ВРег(Поиск)) = 0 Тогда
                Продолжить;
            КонецЕсли;
            Объект = Новый Структура;
            Объект.Вставить("name", Спр.Имя);
            Объект.Вставить("type", "Catalog");
            Объект.Вставить("fields_count", Спр.Реквизиты.Количество());
            МассивОбъектов.Добавить(Объект);
        КонецЦикла;
    КонецЕсли;

    Если ТипОбъекта = "" ИЛИ ТипОбъекта = "Document" Тогда
        Для Каждого Док Из Метаданные.Документы Цикл
            Если ЗначениеЗаполнено(Поиск) И СтрНайти(ВРег(Док.Имя), ВРег(Поиск)) = 0 Тогда
                Продолжить;
            КонецЕсли;
            Объект = Новый Структура;
            Объект.Вставить("name", Док.Имя);
            Объект.Вставить("type", "Document");
            Объект.Вставить("fields_count", Док.Реквизиты.Количество());
            МассивОбъектов.Добавить(Объект);
        КонецЦикла;
    КонецЕсли;

    Если ТипОбъекта = "" ИЛИ ТипОбъекта = "AccumulationRegister" Тогда
        Для Каждого Рег Из Метаданные.РегистрыНакопления Цикл
            Если ЗначениеЗаполнено(Поиск) И СтрНайти(ВРег(Рег.Имя), ВРег(Поиск)) = 0 Тогда
                Продолжить;
            КонецЕсли;
            Объект = Новый Структура;
            Объект.Вставить("name", Рег.Имя);
            Объект.Вставить("type", "AccumulationRegister");
            Объект.Вставить("fields_count", Рег.Ресурсы.Количество() + Рег.Измерения.Количество());
            МассивОбъектов.Добавить(Объект);
        КонецЦикла;
    КонецЕсли;

    Если ТипОбъекта = "" ИЛИ ТипОбъекта = "InformationRegister" Тогда
        Для Каждого Рег Из Метаданные.РегистрыСведений Цикл
            Если ЗначениеЗаполнено(Поиск) И СтрНайти(ВРег(Рег.Имя), ВРег(Поиск)) = 0 Тогда
                Продолжить;
            КонецЕсли;
            Объект = Новый Структура;
            Объект.Вставить("name", Рег.Имя);
            Объект.Вставить("type", "InformationRegister");
            Объект.Вставить("fields_count", Рег.Ресурсы.Количество() + Рег.Измерения.Количество());
            МассивОбъектов.Добавить(Объект);
        КонецЦикла;
    КонецЕсли;

    Возврат СоздатьОтвет(200, Новый Структура("objects", МассивОбъектов));

КонецФункции

Функция StructureGET(Запрос) Экспорт

    ИмяОбъекта = ПолучитьПараметрHTTPЗапроса(Запрос, "name");
    Если ПустаяСтрока(ИмяОбъекта) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Parameter 'name' is required"));
    КонецЕсли;

    ОбъектМД = Неопределено;
    ТипОбъекта = "";

    Для Каждого Спр Из Метаданные.Справочники Цикл
        Если Спр.Имя = ИмяОбъекта Тогда
            ОбъектМД = Спр;
            ТипОбъекта = "Catalog";
            Прервать;
        КонецЕсли;
    КонецЦикла;

    Если ОбъектМД = Неопределено Тогда
        Для Каждого Док Из Метаданные.Документы Цикл
            Если Док.Имя = ИмяОбъекта Тогда
                ОбъектМД = Док;
                ТипОбъекта = "Document";
                Прервать;
            КонецЕсли;
        КонецЦикла;
    КонецЕсли;

    Если ОбъектМД = Неопределено Тогда
        Возврат СоздатьОтвет(404, Новый Структура("error", "Object not found: " + ИмяОбъекта));
    КонецЕсли;

    МассивПолей = Новый Массив;
    Для Каждого Рекв Из ОбъектМД.Реквизиты Цикл
        Поле = Новый Структура;
        Поле.Вставить("name", Рекв.Имя);
        Поле.Вставить("type", Строка(Рекв.Тип));
        Поле.Вставить("synonym", Рекв.Синоним);
        МассивПолей.Добавить(Поле);
    КонецЦикла;

    Результат = Новый Структура;
    Результат.Вставить("name", ИмяОбъекта);
    Результат.Вставить("type", ТипОбъекта);
    Результат.Вставить("fields", МассивПолей);
    Возврат СоздатьОтвет(200, Результат);

КонецФункции

Функция ПолучитьПараметрHTTPЗапроса(Запрос, ИмяПараметра)

    Попытка
        Если Запрос.ПараметрыURL <> Неопределено Тогда
            ЗначениеПараметра = Запрос.ПараметрыURL.Получить(ИмяПараметра);
            Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
                Возврат ЗначениеПараметра;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Попытка
        Если Запрос.ПараметрыЗапроса <> Неопределено Тогда
            ЗначениеПараметра = Запрос.ПараметрыЗапроса.Получить(ИмяПараметра);
            Если ЗначениеЗаполнено(ЗначениеПараметра) Тогда
                Возврат ЗначениеПараметра;
            КонецЕсли;
        КонецЕсли;
    Исключение
    КонецПопытки;

    Возврат "";

КонецФункции

Функция СоздатьОтвет(КодСостояния, Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрJSON = ЗаписьJSON.Закрыть();

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрJSON);
    Возврат Ответ;

КонецФункции
