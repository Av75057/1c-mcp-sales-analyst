// HTTP-сервис: Execute Query
// POST /hs/query/execute — выполнение произвольного запроса (только SELECT)
//
// Вход: {"query": "ВЫБРАТЬ ...", "params": {"Парам1": "Значение1"}}
// Выход: {"columns": [...], "rows": [[...], ...], "count": 100}

Функция ExecutePOST(Запрос) Экспорт

    ТелоЗапроса = ПрочитатьТелоЗапроса(Запрос);
    Если ТелоЗапроса = Неопределено Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Invalid JSON body"));
    КонецЕсли;

    ТекстЗапроса = ТелоЗапроса.Получить("query");
    Если ПустаяСтрока(ТекстЗапроса) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Parameter 'query' is required"));
    КонецЕсли;

    // Read-only guard: проверяем что запрос только на чтение
    ВерхнийЗапрос = ВРег(ТекстЗапроса);
    ЗапрещенныеСлова = Новый Массив;
    ЗапрещенныеСлова.Добавить("ИЗМЕНИТЬ");
    ЗапрещенныеСлова.Добавить("ДОБАВИТЬ");
    ЗапрещенныеСлова.Добавить("УДАЛИТЬ");
    ЗапрещенныеСлова.Добавить("ПОМЕТИТЬУДАЛЕНИЕ");
    ЗапрещенныеСлова.Добавить("ПРОВЕСТИ");
    ЗапрещенныеСлова.Добавить("ЗАПИСАТЬ");

    Для Каждого ЗапрСлово Из ЗапрещенныеСлова Цикл
        Если СтрНайти(ВерхнийЗапрос, ЗапрСлово) > 0 Тогда
            Возврат СоздатьОтвет(403, Новый Структура("error", "Запрещённая операция: " + ЗапрСлово));
        КонецЕсли;
    КонецЦикла;

    // Проверяем, что запрос начинается с ВЫБРАТЬ
    Если Лев(СокрЛП(ВерхнийЗапрос), 6) <> "ВЫБРАТЬ" Тогда
        Возврат СоздатьОтвет(403, Новый Структура("error", "Разрешены только запросы SELECT (ВЫБРАТЬ)"));
    КонецЕсли;

    Попытка

        ЗапросОбъект = Новый Запрос(ТекстЗапроса);

        // Устанавливаем параметры, если есть
        Параметры = ТелоЗапроса.Получить("params");
        Если Параметры <> Неопределено И ТипЗнч(Параметры) = Тип("Соответствие") Тогда
            Для Каждого КлючЗначение Из Параметры Цикл
                Попытка
                    ЗапросОбъект.УстановитьПараметр(КлючЗначение.Ключ, КлючЗначение.Значение);
                Исключение
                КонецПопытки;
            КонецЦикла;
        КонецЕсли;

        Результат = ЗапросОбъект.Выполнить();

        // Определяем колонки
        МассивКолонок = Новый Массив;
        Для Каждого Колонка Из Результат.Колонки Цикл
            МассивКолонок.Добавить(Колонка.Имя);
        КонецЦикла;

        // Получаем данные
        МассивСтрок = Новый Массив;
        Выборка = Результат.Выбрать();
        Пока Выборка.Следующий() Цикл
            СтрокаМассива = Новый Массив;
            Для Каждого ИмяКолонки Из МассивКолонок Цикл
                Значение = Выборка[ИмяКолонки];
                // Преобразуем значение в строку для JSON
                Если ТипЗнч(Значение) = Тип("Строка") Тогда
                    СтрокаМассива.Добавить(Значение);
                ИначеЕсли ТипЗнч(Значение) = Тип("Число") Тогда
                    СтрокаМассива.Добавить(Значение);
                ИначеЕсли ТипЗнч(Значение) = Тип("Булево") Тогда
                    СтрокаМассива.Добавить(?Значение, Истина, Ложь);
                ИначеЕсли ТипЗнч(Значение) = Тип("Дата") Тогда
                    СтрокаМассива.Добавить(Формат(Значение, "ДФ=yyyy-MM-dd'T'HH:mm:ss"));
                Иначе
                    СтрокаМассива.Добавить(Строка(Значение));
                КонецЕсли;
            КонецЦикла;
            МассивСтрок.Добавить(СтрокаМассива);
        КонецЦикла;

        ОтветСтруктура = Новый Структура;
        ОтветСтруктура.Вставить("columns", МассивКолонок);
        ОтветСтруктура.Вставить("rows", МассивСтрок);
        ОтветСтруктура.Вставить("count", МассивСтрок.Количество());

        Возврат СоздатьОтвет(200, ОтветСтруктура);

    Исключение
        Возврат СоздатьОтвет(500, Новый Структура("error", ОписаниеОшибки()));
    КонецПопытки;

КонецФункции

Функция ПрочитатьТелоЗапроса(Запрос)

    Попытка
        ТелоТекст = Запрос.ПолучитьТелоКакСтроку();
        Если ПустаяСтрока(ТелоТекст) Тогда
            Возврат Неопределено;
        КонецЕсли;
        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(ТелоТекст);
        Результат = ПрочитатьJSON(Чтение);
        Чтение.Закрыть();
        Возврат Результат;
    Исключение
        Возврат Неопределено;
    КонецПопытки;

КонецФункции

Функция СоздатьОтвет(КодСостояния, Данные)

    ЗаписьJSON = Новый ЗаписьJSON;
    ЗаписьJSON.УстановитьСтроку();
    ЗаписатьJSON(ЗаписьJSON, Данные);
    СтрJSON = ЗаписьJSON.Закрыть();

    Ответ = Новый HTTPСервисОтвет(КодСостояния);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(СтрJSON);
    Возврат Ответ;

КонецФункции
