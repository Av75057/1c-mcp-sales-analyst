Функция ExecutePOST(Запрос) Экспорт

    // Читаем тело запроса как строку (без JSON)
    ТекстЗапроса = Запрос.ПолучитьТелоКакСтроку();
    Если ПустаяСтрока(ТекстЗапроса) Тогда
        Возврат СоздатьОтвет(400, Новый Структура("error", "Empty body"));
    КонецЕсли;

    // Проверка: только SELECT
    ВерхЗапрос = ВРег(ТекстЗапроса);
    Если Лев(СокрЛП(ВерхЗапрос), 7) <> "ВЫБРАТЬ" Тогда
        Возврат СоздатьОтвет(403, Новый Структура("error", "Только SELECT"));
    КонецЕсли;

    // Read-only guard
    Запрещенные = Новый Массив;
    Запрещенные.Добавить("ИЗМЕНИТЬ");
    Запрещенные.Добавить("ДОБАВИТЬ");
    Запрещенные.Добавить("УДАЛИТЬ");
    Запрещенные.Добавить("ПОМЕТИТЬУДАЛЕНИЕ");
    Запрещенные.Добавить("ПРОВЕСТИ");
    Запрещенные.Добавить("ЗАПИСАТЬ");
    Для Каждого Слово Из Запрещенные Цикл
        Если СтрНайти(ВерхЗапрос, Слово) > 0 Тогда
            Возврат СоздатьОтвет(403, Новый Структура("error", "Запрещено: " + Слово));
        КонецЕсли;
    КонецЦикла;

    Попытка
        ЗапросОбъект = Новый Запрос(ТекстЗапроса);
        Результат = ЗапросОбъект.Выполнить();

        // Колонки
        Колонки = Новый Массив;
        Для Каждого Кол Из Результат.Колонки Цикл
            Колонки.Добавить(Кол.Имя);
        КонецЦикла;

        // Данные
        Строки = Новый Массив;
        Выборка = Результат.Выбрать();
        Пока Выборка.Следующий() Цикл
            Строка = Новый Массив;
            Для Каждого ИмяКол Из Колонки Цикл
                Знч = Выборка[ИмяКол];
                Если ТипЗнч(Знч) = Тип("Строка") Тогда
                    Строка.Добавить(Знч);
                ИначеЕсли ТипЗнч(Знч) = Тип("Число") Тогда
                    Строка.Добавить(Знч);
                ИначеЕсли ТипЗнч(Знч) = Тип("Дата") Тогда
                    Строка.Добавить(Формат(Знч, "ДФ=yyyy-MM-dd'T'HH:mm:ss"));
                Иначе
                    Строка.Добавить(Строка(Знч));
                КонецЕсли;
            КонецЦикла;
            Строки.Добавить(Строка);
        КонецЦикла;

        Ответ = Новый Структура;
        Ответ.Вставить("columns", Колонки);
        Ответ.Вставить("rows", Строки);
        Ответ.Вставить("count", Строки.Количество());
        Возврат СоздатьОтвет(200, Ответ);

    Исключение
        Возврат СоздатьОтвет(500, Новый Структура("error", ОписаниеОшибки()));
    КонецПопытки;

КонецФункции

Функция СоздатьОтвет(Код, Данные)
    Запись = Новый ЗаписьJSON;
    Запись.УстановитьСтроку();
    ЗаписатьJSON(Запись, Данные);
    Стр = Запись.Закрыть();
    Ответ = Новый HTTPСервисОтвет(Код);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");
    Ответ.УстановитьТелоИзСтроки(Стр);
    Возврат Ответ;
КонецФункции
