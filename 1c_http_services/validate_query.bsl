// HTTP-сервис: validate_query
// POST /hs/api/validate_query — проверка синтаксиса запроса без выполнения
//
// Вход: {"query": "ВЫБРАТЬ ...", "params": {"Парам1": "Значение1"}}
// Выход: {"is_valid": true/false, "error": "...", "error_line": N, "suggestion": "..."}

Функция ValidateQueryHTTP(Запрос) Экспорт

    Ответ = Новый HTTPСервисОтвет(200);
    Ответ.Заголовки.Вставить("Content-Type", "application/json;charset=utf-8");

    Попытка
        ТелоТекст = Запрос.ПолучитьТелоКакСтроку();
        Если ПустаяСтрока(ТелоТекст) Тогда
            Ответ.УстановитьТелоИзСтроки(JSONСтрока(Новый Структура("is_valid, error", Ложь, "Пустое тело запроса")));
            Возврат Ответ;
        КонецЕсли;

        Чтение = Новый ЧтениеJSON;
        Чтение.УстановитьСтроку(ТелоТекст);
        Данные = ПрочитатьJSON(Чтение);
        Чтение.Закрыть();

        ТекстЗапроса = Данные.query;
        Если ПустаяСтрока(ТекстЗапроса) Тогда
            Ответ.УстановитьТелоИзСтроки(JSONСтрока(Новый Структура("is_valid, error", Ложь, "query is required")));
            Возврат Ответ;
        КонецЕсли;

        Результат = ПроверитьЗапрос(ТекстЗапроса);

        СтруктураОтвета = Новый Структура;
        СтруктураОтвета.Вставить("is_valid", Результат.Валиден);
        Если НЕ Результат.Валиден Тогда
            СтруктураОтвета.Вставить("error", Результат.ОписаниеОшибки);
            СтруктураОтвета.Вставить("error_line", Результат.НомерСтроки);
            СтруктураОтвета.Вставить("suggestion", Результат.Подсказка);
        КонецЕсли;

        Ответ.УстановитьТелоИзСтроки(JSONСтрока(СтруктураОтвета));

    Исключение
        Ошибка = Новый Структура("is_valid, error", Ложь, ОписаниеОшибки());
        Ответ.УстановитьТелоИзСтроки(JSONСтрока(Ошибка));
    КонецПопытки;

    Возврат Ответ;

КонецФункции


Функция ПроверитьЗапрос(ТекстЗапроса)

    Результат = Новый Структура("Валиден, ОписаниеОшибки, НомерСтроки, Подсказка", Ложь, "", 0, "");

    Если ПустаяСтрока(ТекстЗапроса) Тогда
        Результат.ОписаниеОшибки = "Запрос пустой";
        Результат.Подсказка = "Введите текст запроса";
        Возврат Результат;
    КонецЕсли;

    Если СтрДлина(ТекстЗапроса) > 5000 Тогда
        Результат.ОписаниеОшибки = "Запрос слишком длинный (макс. 5000 символов)";
        Результат.Подсказка = "Сократите запрос";
        Возврат Результат;
    КонецЕсли;

    Верх = ВРег(ТекстЗапроса);
    Запрет = Новый Массив;
    Запрет.Добавить("ИЗМЕНИТЬ"); Запрет.Добавить("ИЗМЕНЕНИЕ"); Запрет.Добавить("УДАЛИТЬ"); Запрет.Добавить("УДАЛЕНИЕ");
    Запрет.Добавить("ДОБАВИТЬ"); Запрет.Добавить("ОБНОВИТЬ");
    Запрет.Добавить("INSERT"); Запрет.Добавить("UPDATE"); Запрет.Добавить("DELETE");
    Запрет.Добавить("DROP"); Запрет.Добавить("CREATE"); Запрет.Добавить("ALTER");
    Запрет.Добавить("TRUNCATE"); Запрет.Добавить("EXEC");

    Для Каждого С Из Запрет Цикл
        Если СтрНайти(Верх, С) > 0 Тогда
            Результат.ОписаниеОшибки = "Запрещённая операция: " + С;
            Результат.Подсказка = "Разрешены только запросы на выборку данных (SELECT/ВЫБРАТЬ)";
            Возврат Результат;
        КонецЕсли;
    КонецЦикла;

    Попытка
        Построитель = Новый ПостроительЗапроса;
        Построитель.Текст = ТекстЗапроса;
        Результат.Валиден = Истина;
    Исключение
        Результат.Валиден = Ложь;
        Результат.ОписаниеОшибки = ОписаниеОшибки();
        Результат.Подсказка = "Проверьте синтаксис запроса";
    КонецПопытки;

    Возврат Результат;

КонецФункции


Функция JSONСтрока(Данные)
    Запись = Новый ЗаписьJSON;
    Запись.УстановитьСтроку();
    ЗаписатьJSON(Запись, Данные);
    Возврат Запись.Закрыть();
КонецФункции
