Функция searchNomenclature(Запрос) Экспорт

    ПоискЗакодирован = ПолучитьПараметрHTTPЗапроса(Запрос, "q");
    ЛимитСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "limit");

    Если НЕ ЗначениеЗаполнено(ЛимитСтр) Тогда
        Лимит = 20;
    Иначе
        Лимит = Число(ЛимитСтр);
    КонецЕсли;

    Поиск = РаскодироватьURL(ПоискЗакодирован);
    Шаблон = "%" + СтрЗаменить(Поиск, " ", "%") + "%";

    ТекстЗапроса =
    "ВЫБРАТЬ ПЕРВЫЕ " + Лимит + "
    |    Номенклатура.Ссылка,
    |    Номенклатура.Наименование,
    |    Номенклатура.ЕдиницаИзмерения.Наименование КАК Единица,
    |    Номенклатура.ТипНоменклатуры КАК Тип
    |ИЗ
    |    Справочник.Номенклатура КАК Номенклатура
    |ГДЕ
    |    Номенклатура.Наименование ПОДОБНО &Шаблон
    |УПОРЯДОЧИТЬ ПО
    |    Номенклатура.Наименование";

    Попытка
        ЗапросОбъект = Новый Запрос(ТекстЗапроса);
        ЗапросОбъект.УстановитьПараметр("Шаблон", Шаблон);

        Выборка = ЗапросОбъект.Выполнить().Выбрать();

        МассивРезультата = Новый Массив;
        Пока Выборка.Следующий() Цикл
            Стр = Новый Структура;
            Стр.Вставить("ref", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
            Стр.Вставить("name", Строка(Выборка.Наименование));
            Стр.Вставить("unit", Строка(Выборка.Единица));
            Стр.Вставить("item_type", Строка(Выборка.Тип));
            МассивРезультата.Добавить(Стр);
        КонецЦикла;

        ЗаписьJSON = Новый ЗаписьJSON;
        ЗаписьJSON.УстановитьСтроку();
        ЗаписатьJSON(ЗаписьJSON, МассивРезультата);
        ТелоОтвета = ЗаписьJSON.Закрыть();

        Ответ = Новый HTTPСервисОтвет(200);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки(ТелоОтвета);
        Возврат Ответ;

    Исключение
        Ответ = Новый HTTPСервисОтвет(500);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки("{""error"": """ + ОписаниеОшибки() + """}");
        Возврат Ответ;
    КонецПопытки;

КонецФункции

Функция РаскодироватьURL(Знач Строка)

    Результат = "";
    Длина = СтрДлина(Строка);
    Позиция = 1;

    Пока Позиция <= Длина Цикл
        Сим = Сред(Строка, Позиция, 1);
        Если Сим = "+" Тогда
            Результат = Результат + " ";
            Позиция = Позиция + 1;
        ИначеЕсли Сим = "%" Тогда
            Код = Сред(Строка, Позиция + 1, 2);
            Если Код = "" Тогда
                Прервать;
            КонецЕсли;
            Результат = Результат + Символ(ИзX(Код));
            Позиция = Позиция + 3;
        Иначе
            Результат = Результат + Сим;
            Позиция = Позиция + 1;
        КонецЕсли;
    КонецЦикла;

    Возврат Результат;

КонецФункции
