Функция searchNomenclature(Запрос) Экспорт

    ПоискСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "q");
    ЛимитСтр = ПолучитьПараметрHTTPЗапроса(Запрос, "limit");

    // 1С на IIS не декодирует UTF-8, поэтому Python шлёт в CP1251
    Поиск = ПоискСтр;

    Если Не ЗначениеЗаполнено(ЛимитСтр) Тогда
        Лимит = 20;
    Иначе
        Лимит = Число(ЛимитСтр);
    КонецЕсли;

    ТекстЗапроса =
    "ВЫБРАТЬ ПЕРВЫЕ " + Лимит + "
    |    Номенклатура.Ссылка,
    |    Номенклатура.Наименование,
    |    Номенклатура.ЕдиницаИзмерения.Наименование КАК Единица,
    |    Номенклатура.ТипНоменклатуры КАК Тип
    |ИЗ
    |    Справочник.Номенклатура КАК Номенклатура
    |ГДЕ
    |    Номенклатура.Наименование ПОДОБНО &Поиск
    |    И Номенклатура.ПометкаУдаления = Ложь
    |УПОРЯДОЧИТЬ ПО
    |    Номенклатура.Наименование";

    Попытка
        ЗапросОбъект = Новый Запрос(ТекстЗапроса);
        ЗапросОбъект.УстановитьПараметр("Поиск", "%" + Поиск + "%");

        Выборка = ЗапросОбъект.Выполнить().Выбрать();

        МассивРезультата = Новый Массив;

        Пока Выборка.Следующий() Цикл
            Строка = Новый Структура;
            Строка.Вставить("ref", Строка(Выборка.Ссылка.УникальныйИдентификатор()));
            Строка.Вставить("name", Строка(Выборка.Наименование));
            Строка.Вставить("unit", Строка(Выборка.Единица));
            Строка.Вставить("item_type", Строка(Выборка.Тип));
            МассивРезультата.Добавить(Строка);
        КонецЦикла;

        ЗаписьJSON = Новый ЗаписьJSON;
        ЗаписьJSON.УстановитьСтроку();
        ЗаписатьJSON(ЗаписьJSON, МассивРезультата);
        ТелоОтвета = ЗаписьJSON.Закрыть();

        Ответ = Новый HTTPСервисОтвет(200);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки(ТелоОтвета);
        Возврат Ответ;

    Исключение
        Ответ = Новый HTTPСервисОтвет(500);
        Ответ.Заголовки.Вставить("Content-Type", "application/json; charset=utf-8");
        Ответ.УстановитьТелоИзСтроки("{""error"": """ + ОписаниеОшибки() + """}");
        Возврат Ответ;
    КонецПопытки;

КонецФункции
