  <grace:milestone id="phase6" status="pending" description="GRACE-интеграция и семантическая разметка">
    <grace:task status="done">docs/requirements.xml — контракты всех 19 MCP инструментов</grace:task>
    <grace:task status="done">docs/knowledge-graph.xml — граф 10 объектов 1С → 19 инструментов</grace:task>
    <grace:task status="done">docs/development-plan.xml — модульные контракты и план</grace:task>
