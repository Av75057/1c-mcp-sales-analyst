  <grace:milestone id="phase4" status="completed" description="Metadata API, batch-запросы, документы, nginx, CI/CD">
    <grace:task status="done">1c_http_services/batch_endpoint.bsl — batch-эндпоинт</grace:task>
    <grace:task status="done">1c_http_services/metadata_api.bsl — config/describe/structure</grace:task>
    <grace:task status="done">1c_http_services/execute_query.bsl — произвольные SELECT-запросы</grace:task>
    <grace:task status="done">1c_http_services/documents_sales.bsl — документы с пагинацией</grace:task>
    <grace:task status="done">deploy/nginx.conf — обратный прокси</grace:task>
    <grace:task status="done">.github/workflows/ — CI/CD</grace:task>
  </grace:milestone>

  <grace:milestone id="phase5" status="completed" description="Админ-панель, безопасность, observability, telegram dashboard">
    <grace:task status="done">src/admin/ — пользователи, API-ключи, аудит, мониторинг</grace:task>
    <grace:task status="done">src/auth/ — JWT, роли, middleware</grace:task>
    <grace:task status="done">src/security/ — rate limit, CSP, readonly guard, шифрование</grace:task>
    <grace:task status="done">src/observability/ — Prometheus метрики, structlog</grace:task>
    <grace:task status="done">src/proactive/ — APScheduler с ежедневными отчетами</grace:task>
