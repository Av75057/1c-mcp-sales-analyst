  <grace:edge from="abc_xyz_analysis" to="AccumulationRegister.Продажи" type="reads" />
  <grace:edge from="abc_xyz_analysis" to="Catalog.Номенклатура" type="reads" />
  <grace:edge from="abc_xyz_analysis" to="Catalog.Контрагенты" type="reads" />

  <grace:edge from="simulate_scenario" to="AccumulationRegister.Продажи" type="reads" />
  <grace:edge from="simulate_scenario" to="Catalog.Номенклатура" type="reads" />

  <grace:edge from="config" to="MetadataService.get_config" type="reads" />
